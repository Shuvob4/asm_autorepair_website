---
import businessInfo from '../../data/business-info.json';

const { address, phone, phoneDisplay, email, whatsappUrl } = businessInfo;
const whatsappGreeting = encodeURIComponent(
  "Hi ASM AUTO Repair, I'd like to inquire about your services."
);
const whatsappLink = `${whatsappUrl}?text=${whatsappGreeting}`;
---

<section class="contact-info" aria-label="Contact Information">
  <h2 class="contact-info__title">Get in Touch</h2>

  <address class="contact-info__details">
    <!-- Address -->
    <div class="contact-info__item">
      <svg class="contact-info__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
        <circle cx="12" cy="10" r="3"></circle>
      </svg>
      <span class="contact-info__text">{address.full}</span>
    </div>

    <!-- Phone -->
    <div class="contact-info__item">
      <svg class="contact-info__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
      </svg>
      <a href={`tel:${phone}`} class="contact-info__link">
        {phoneDisplay}
      </a>
    </div>

    <!-- Email -->
    <div class="contact-info__item">
      <svg class="contact-info__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
        <polyline points="22,6 12,13 2,6"></polyline>
      </svg>
      <a href={`mailto:${email}`} class="contact-info__link">
        {email}
      </a>
    </div>

    <!-- WhatsApp -->
    <div class="contact-info__item contact-info__item--whatsapp">
      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="contact-info__whatsapp-btn"
        aria-label="Message us on WhatsApp"
      >
        <svg class="contact-info__whatsapp-icon" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span>Chat on WhatsApp</span>
      </a>
    </div>
  </address>
</section>

<style>
  .contact-info {
    padding: var(--space-md);
  }

  .contact-info__title {
    font-family: var(--font-family);
    font-size: var(--text-h4);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-heading);
    margin-bottom: var(--space-sm);
    color: var(--color-primary);
  }

  .contact-info__details {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .contact-info__item {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    min-height: var(--touch-min);
  }

  .contact-info__icon {
    flex-shrink: 0;
    color: var(--color-secondary);
  }

  .contact-info__text {
    font-size: var(--text-body);
    line-height: var(--line-height-body);
    color: var(--color-primary);
  }

  .contact-info__link {
    font-size: var(--text-body);
    line-height: var(--line-height-body);
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
    min-height: var(--touch-min);
    display: inline-flex;
    align-items: center;
    transition: color var(--transition-fast);
  }

  .contact-info__link:hover,
  .contact-info__link:focus-visible {
    color: var(--color-accent);
  }

  .contact-info__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: var(--border-radius-xs);
  }

  .contact-info__item--whatsapp {
    margin-top: var(--space-xs);
  }

  .contact-info__whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-sm);
    min-height: var(--touch-min);
    min-width: var(--touch-min);
    background-color: #25D366;
    color: var(--color-white);
    font-size: var(--text-body);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    border-radius: var(--border-radius-sm);
    transition: background-color var(--transition-fast), transform var(--transition-fast);
  }

  .contact-info__whatsapp-btn:hover {
    background-color: #1da851;
    transform: translateY(-1px);
  }

  .contact-info__whatsapp-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .contact-info__whatsapp-icon {
    flex-shrink: 0;
  }
</style>
