---
/**
 * FloatingCTA — Fixed-position mobile CTAs (click-to-call + WhatsApp).
 * Visible only on viewports ≤768px. Static component, no JS required.
 *
 * Requirements: 9.1, 9.2, 9.3, 9.4, 9.5, 9.6
 */
---

<div class="floating-cta" role="group" aria-label="Quick contact options">
  <a
    href="tel:+13435585301"
    class="floating-cta__btn floating-cta__btn--phone"
    aria-label="Call ASM AUTO Repair"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
    </svg>
  </a>

  <a
    href="https://wa.me/13435585301?text=Hi%20ASM%20AUTO%20Repair%2C%20I%27d%20like%20to%20inquire%20about%20your%20services."
    class="floating-cta__btn floating-cta__btn--whatsapp"
    aria-label="Message on WhatsApp"
    target="_blank"
    rel="noopener noreferrer"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
    </svg>
  </a>
</div>

<style>
  .floating-cta {
    display: none;
    position: fixed;
    bottom: var(--space-sm);
    left: 50%;
    transform: translateX(-50%);
    z-index: var(--z-floating-cta);
    gap: var(--touch-gap);
    align-items: center;
    justify-content: center;
    padding: var(--space-xs) var(--space-sm);
    background: rgba(10, 10, 10, 0.85);
    border-radius: 999px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* Visible only on mobile (≤768px) */
  @media (max-width: 768px) {
    .floating-cta {
      display: flex;
    }
  }

  .floating-cta__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: var(--touch-min);
    min-height: var(--touch-min);
    width: 52px;
    height: 52px;
    border-radius: 50%;
    text-decoration: none;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  .floating-cta__btn:hover {
    transform: scale(1.08);
  }

  .floating-cta__btn:active {
    transform: scale(0.95);
  }

  .floating-cta__btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .floating-cta__btn--phone {
    background-color: var(--color-accent);
    color: var(--color-primary);
  }

  .floating-cta__btn--whatsapp {
    background-color: #25D366;
    color: var(--color-white);
  }
</style>
