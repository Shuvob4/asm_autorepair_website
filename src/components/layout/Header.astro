---
/**
 * Header — Site-wide navigation header
 * 
 * Desktop (≥768px): Full horizontal nav with logo, nav links, and CTA
 * Mobile (<768px): Logo + hamburger menu icon (MobileNav island handles overlay)
 * 
 * Sticky at top. On mobile homepage, header starts transparent and becomes
 * solid after scrolling past the hero section (IntersectionObserver).
 * 
 * Requirements: 19.4, 8.2
 */
import FeatureFlag from '../shared/FeatureFlag.astro';

interface Props {
  transparentOnMobile?: boolean;
}

const { transparentOnMobile = false } = Astro.props;

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'About', href: '/about' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'Contact', href: '/contact' },
  { label: 'Posts', href: '/posts' },
];
---

<header class="site-header" id="site-header" data-transparent-header={transparentOnMobile ? "true" : undefined}>
  <div class="header-container">
    <!-- Logo / Shop name -->
    <a href="/" class="header-logo" aria-label="ASM AUTO Repair - Home">
      ASM AUTO Repair
    </a>

    <!-- Desktop navigation -->
    <nav class="header-nav" aria-label="Main navigation">
      <ul class="nav-list">
        {navLinks.map(({ label, href }) => (
          <li class="nav-item">
            <a href={href} class="nav-link">{label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Desktop CTA -->
    <div class="header-actions">
      <FeatureFlag feature="booking">
        <!-- Phase 2: Book Appointment CTA will go here -->
        <a href="/book" class="header-cta header-cta--booking">Book Appointment</a>
      </FeatureFlag>
      <a href="/quote" class="header-cta">Get a Quote</a>
    </div>

    <!-- Mobile CTA (visible after scrolling past hero on <768px) -->
    <a href="/quote" class="header-cta-mobile" aria-label="Get a Quote">
      Get a Quote
    </a>

    <!-- Mobile hamburger button (MobileNav island will handle the overlay) -->
    <button
      class="hamburger-btn"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-nav-overlay"
      id="hamburger-toggle"
      type="button"
    >
      <span class="hamburger-icon" aria-hidden="true">
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </span>
    </button>
  </div>

  <!-- Slot for MobileNav island (added by BaseLayout or page) -->
  <slot />
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    background-color: var(--color-primary);
    width: 100%;
    transition: background-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  /* On mobile homepage, header starts transparent until hero is scrolled past */
  @media (max-width: 767px) {
    .site-header[data-transparent-header="true"] {
      background-color: transparent;
    }

    .site-header[data-transparent-header="true"]:global(.header--scrolled) {
      background-color: var(--color-primary);
    }
  }

  /* Visual distinction when scrolled past hero */
  :global(.header--scrolled).site-header {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    padding: var(--space-sm) var(--space-md);
  }

  /* ─── Logo ─── */
  .header-logo {
    color: var(--color-white);
    font-family: var(--font-family);
    font-size: var(--text-h4);
    font-weight: var(--font-weight-extrabold);
    text-decoration: none;
    letter-spacing: -0.5px;
    white-space: nowrap;
    transition: opacity var(--transition-fast);
  }

  .header-logo:hover {
    opacity: 0.85;
  }

  .header-logo:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: var(--border-radius-xs);
  }

  /* ─── Desktop Navigation ─── */
  .header-nav {
    display: none;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    list-style: none;
  }

  .nav-link {
    color: var(--color-white);
    font-family: var(--font-family);
    font-size: var(--text-small);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: var(--space-xs) 0;
    transition: color var(--transition-fast), opacity var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: var(--border-radius-xs);
  }

  /* ─── Desktop CTA Button ─── */
  .header-actions {
    display: none;
    align-items: center;
    gap: var(--space-sm);
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 20px;
    background-color: var(--color-accent);
    color: var(--color-primary);
    font-family: var(--font-family);
    font-size: var(--text-small);
    font-weight: var(--font-weight-bold);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1px;
    border-radius: var(--border-radius-xs);
    min-height: var(--touch-min);
    min-width: var(--touch-min);
    white-space: nowrap;
    transition: background-color var(--transition-fast), transform var(--transition-fast);
  }

  .header-cta:hover {
    background-color: #d4a800;
  }

  .header-cta:active {
    transform: scale(0.97);
  }

  .header-cta:focus-visible {
    outline: 2px solid var(--color-white);
    outline-offset: 2px;
  }

  /* ─── Mobile CTA (hidden by default, shown after scrolling past hero) ─── */
  .header-cta-mobile {
    display: none;
    align-items: center;
    justify-content: center;
    padding: 8px 14px;
    background-color: var(--color-accent);
    color: var(--color-primary);
    font-family: var(--font-family);
    font-size: 12px;
    font-weight: var(--font-weight-bold);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-radius: var(--border-radius-xs);
    min-height: var(--touch-min);
    min-width: var(--touch-min);
    white-space: nowrap;
    transition: background-color var(--transition-fast), transform var(--transition-fast), opacity var(--transition-fast);
    opacity: 0;
    pointer-events: none;
  }

  .header-cta-mobile:hover {
    background-color: #d4a800;
  }

  .header-cta-mobile:active {
    transform: scale(0.97);
  }

  .header-cta-mobile:focus-visible {
    outline: 2px solid var(--color-white);
    outline-offset: 2px;
  }

  /* ─── Hamburger Button (mobile only) ─── */
  .hamburger-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--touch-min);
    height: var(--touch-min);
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-xs);
  }

  .hamburger-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: var(--border-radius-xs);
  }

  .hamburger-icon {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 24px;
    height: 24px;
  }

  .hamburger-bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-white);
    border-radius: 1px;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  /* ─── Desktop breakpoint (≥768px) ─── */
  @media (min-width: 768px) {
    .header-nav {
      display: block;
    }

    .header-actions {
      display: flex;
    }

    .hamburger-btn {
      display: none;
    }

    /* Mobile CTA never shows on desktop */
    .header-cta-mobile {
      display: none !important;
    }
  }

  /* ─── Mobile breakpoint (<768px): show mobile CTA when header is scrolled ─── */
  @media (max-width: 767px) {
    .header-cta-mobile {
      display: inline-flex;
    }

    :global(.header--scrolled) .header-cta-mobile {
      opacity: 1;
      pointer-events: auto;
    }
  }
</style>

<script>
  // IntersectionObserver: toggle .header--scrolled class when hero exits viewport
  // This enables the compact mobile CTA to appear in the sticky header
  document.addEventListener('DOMContentLoaded', () => {
    const hero = document.getElementById('hero-section');
    const header = document.getElementById('site-header');

    if (!hero || !header) return;

    const observer = new IntersectionObserver(
      ([entry]) => {
        // When hero is NOT intersecting (scrolled past), add scrolled class
        if (!entry.isIntersecting) {
          header.classList.add('header--scrolled');
        } else {
          header.classList.remove('header--scrolled');
        }
      },
      {
        root: null,
        threshold: 0,
        rootMargin: '0px',
      }
    );

    observer.observe(hero);
  });
</script>
