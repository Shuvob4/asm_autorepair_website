---
import Card from '../shared/Card.astro';
import { formatDate, truncateText } from '../../lib/format';

interface Props {
  title: string;
  slug: string;
  publishedDate: Date;
  featuredImage: string;
  excerpt?: string;
  headingLevel?: 'h2' | 'h3';
}

const { title, slug, publishedDate, featuredImage, excerpt, headingLevel = 'h3' } = Astro.props;

const displayExcerpt = excerpt ? truncateText(excerpt, 160) : '';
const formattedDate = formatDate(publishedDate);
const Heading = headingLevel;
---

<Card class="post-card">
  <a href={`/posts/${slug}`} class="post-card__link">
    <img
      src={featuredImage}
      alt={title}
      class="post-card__image"
      loading="lazy"
      width="400"
      height="225"
    />
    <div class="post-card__content">
      <Heading class="post-card__title">{title}</Heading>
      <time class="post-card__date" datetime={publishedDate.toISOString()}>
        {formattedDate}
      </time>
      {displayExcerpt && <p class="post-card__excerpt">{displayExcerpt}</p>}
    </div>
  </a>
</Card>

<style>
  .post-card {
    padding: 0;
    overflow: hidden;
  }

  .post-card__link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .post-card__link:hover .post-card__title {
    color: var(--color-accent);
  }

  .post-card__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: var(--border-radius);
  }

  .post-card__image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: var(--border-radius) var(--border-radius) 0 0;
  }

  .post-card__content {
    padding: var(--space-md);
  }

  .post-card__title {
    font-family: var(--font-family);
    font-size: var(--text-h4);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
    margin: 0 0 var(--space-xs) 0;
    line-height: var(--line-height-heading);
    transition: color var(--transition-fast);
  }

  .post-card__date {
    display: block;
    font-size: var(--text-small);
    color: var(--color-secondary);
    margin-bottom: var(--space-sm);
  }

  .post-card__excerpt {
    font-size: var(--text-body);
    color: var(--color-secondary);
    line-height: var(--line-height-body);
    margin: 0;
  }

  @media (min-width: 768px) {
    .post-card__image {
      height: 220px;
    }
  }
</style>
