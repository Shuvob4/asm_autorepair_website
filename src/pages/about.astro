---
/**
 * About Page — Shop history, expertise, equipment, team, and contact info.
 * Requirements: 3.1, 3.2, 3.3, 16.3
 */
import BaseLayout from '../components/layout/BaseLayout.astro';
import SectionHeading from '../components/shared/SectionHeading.astro';
import businessInfo from '../data/business-info.json';
---

<BaseLayout
  title="About Us · ASM AUTO Repair Toronto"
  description="Years of trusted auto repair experience in Toronto. Done-right-the-first-time guarantee at 296 Brock Ave."
  canonical="https://asmautomotive.com/about/"
>
  <section class="about-page">
    <div class="about-page__container">
      <SectionHeading tag="h1">About ASM AUTO Repair</SectionHeading>

      <!-- Our Story -->
      <div class="about-page__section">
        <SectionHeading tag="h2">Our Story</SectionHeading>
        <p>
          For over 15+ years, ASM AUTO Repair has served the Toronto community with honest,
          reliable auto repair services. What started as a small neighbourhood shop on Brock Avenue
          has grown into a trusted destination for drivers across the Greater Toronto Area who demand
          quality workmanship and transparent pricing.
        </p>
        <p>
          Our philosophy is simple: every repair is done right the first time. We believe that cutting
          corners costs more in the long run — both for our customers and for our reputation. That
          commitment to getting it right has earned us loyal customers who return year after year and
          recommend us to their friends and family.
        </p>
        <p>
          At ASM AUTO Repair, we treat every vehicle as if it were our own. From routine oil changes
          to complex engine diagnostics, our team approaches each job with the same care and attention
          to detail that has defined our shop since day one.
        </p>
      </div>

      <!-- Our Expertise -->
      <div class="about-page__section">
        <SectionHeading tag="h2">Our Expertise</SectionHeading>
        <p>
          Our technicians bring deep technical knowledge across all makes and models, from domestic
          vehicles to European imports and Asian brands. We stay current with the latest automotive
          technologies, attending regular training and certification programs to ensure we can handle
          modern computerised engine management systems, advanced transmission controls, and hybrid
          vehicle components. Whether your car needs a straightforward brake service or a complex
          electrical diagnosis, our team has the expertise to identify the problem accurately and
          deliver a lasting repair.
        </p>
      </div>

      <!-- Our Equipment -->
      <div class="about-page__section">
        <SectionHeading tag="h2">Our Equipment</SectionHeading>
        <p>
          We invest in the latest diagnostic tools and repair equipment to ensure precise, efficient
          service for every vehicle that enters our shop. Our facility features advanced OBD-II
          scanning systems, professional-grade alignment machines, and modern lift equipment that
          meets or exceeds manufacturer specifications. By using high-quality tools and genuine or
          OEM-equivalent parts, we deliver repairs that last — not just quick fixes that bring you
          back next month.
        </p>
      </div>

      <!-- Team Qualifications -->
      <div class="about-page__section">
        <SectionHeading tag="h2">Our Team</SectionHeading>
        <p>
          Our experienced team of certified technicians brings decades of combined expertise to every
          job. Each member of our crew is dedicated to continuing education, staying up-to-date with
          evolving automotive technology so that you receive the highest standard of care for your
          vehicle.
        </p>
      </div>

      <!-- Contact Info -->
      <div class="about-page__section about-page__contact">
        <SectionHeading tag="h2">Visit Us</SectionHeading>
        <ul class="about-page__contact-list">
          <li>
            <strong>Address:</strong>
            <span>{businessInfo.address.full}</span>
          </li>
          <li>
            <strong>Phone:</strong>
            <a href={`tel:${businessInfo.phone}`}>{businessInfo.phoneDisplay}</a>
          </li>
          <li>
            <strong>Email:</strong>
            <a href={`mailto:${businessInfo.email}`}>{businessInfo.email}</a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-page {
    padding: var(--space-xl) 0;
  }

  .about-page__container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .about-page__section {
    margin-bottom: var(--space-xl);
  }

  .about-page__section p {
    font-family: var(--font-family);
    font-size: var(--text-body);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-body);
    color: var(--color-primary);
    margin-bottom: var(--space-md);
  }

  .about-page__contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .about-page__contact-list li {
    font-family: var(--font-family);
    font-size: var(--text-body);
    line-height: var(--line-height-body);
    color: var(--color-primary);
  }

  .about-page__contact-list a {
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  .about-page__contact-list a:hover {
    opacity: 0.8;
  }

  .about-page__contact-list a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
