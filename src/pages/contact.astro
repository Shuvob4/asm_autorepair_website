---
/**
 * Contact & Location Page — Address, phone, email, WhatsApp, business hours,
 * open/closed indicator, and Google Maps embed.
 * Requirements: 5.1–5.8, 16.3
 */
import BaseLayout from '../components/layout/BaseLayout.astro';
import SectionHeading from '../components/shared/SectionHeading.astro';
import ContactInfo from '../components/contact/ContactInfo.astro';
import BusinessHours from '../components/contact/BusinessHours.astro';
import OpenNowIndicator from '../components/contact/OpenNowIndicator.tsx';
import GoogleMap from '../components/contact/GoogleMap.tsx';
import FeatureFlag from '../components/shared/FeatureFlag.astro';
---

<BaseLayout
  title="Contact & Location · ASM AUTO Repair Toronto"
  description="Visit ASM AUTO Repair at 296 Brock Ave, Toronto. Call (416) 516-8181 or WhatsApp us. Open Mon–Sat."
  canonical="https://asmautomotive.com/contact/"
>
  <section class="contact-page">
    <div class="contact-page__container">
      <SectionHeading tag="h1">Contact &amp; Location</SectionHeading>

      <div class="contact-page__grid">
        <!-- Left column: contact info, hours, open/closed -->
        <div class="contact-page__left">
          <ContactInfo />
          <BusinessHours />
          <div class="contact-page__open-now">
            <OpenNowIndicator client:load />
          </div>
        </div>

        <!-- Right column: map -->
        <div class="contact-page__right">
          <GoogleMap client:visible />
        </div>
      </div>

      <!-- Phase 2: Appointment booking widget (hidden until FEATURE_BOOKING_ENABLED=true) -->
      <FeatureFlag feature="booking">
        <section class="contact-page__booking">
          <SectionHeading tag="h2">Book an Appointment</SectionHeading>
          <!-- Future booking widget will go here (Phase 2) -->
          <div class="booking-placeholder">
            <p>Online booking coming soon.</p>
          </div>
        </section>
      </FeatureFlag>

      <!-- Phase 3: Email notification preferences (hidden until FEATURE_EMAIL_ENABLED=true) -->
      <FeatureFlag feature="email">
        <section class="contact-page__email-prefs">
          <!-- Future email notification preferences will go here (Phase 3) -->
          <div class="email-prefs-placeholder">
            <p>Email notification preferences coming soon.</p>
          </div>
        </section>
      </FeatureFlag>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    padding: var(--space-xl) 0;
  }

  .contact-page__container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .contact-page__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .contact-page__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact-page__right {
    min-height: 400px;
  }

  .contact-page__open-now {
    padding: 0 var(--space-md);
  }

  /* Desktop: 2-column layout */
  @media (min-width: 768px) {
    .contact-page__grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }

    .contact-page__right {
      position: sticky;
      top: var(--space-lg);
    }
  }

  /* OpenNowIndicator styles (Preact island uses these class names) */
  :global(.open-now-indicator) {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--border-radius-sm);
    font-family: var(--font-family);
    font-size: var(--text-body);
    font-weight: var(--font-weight-medium);
  }

  :global(.open-now-indicator--open) {
    background-color: rgba(34, 197, 94, 0.1);
    color: #166534;
  }

  :global(.open-now-indicator--closed) {
    background-color: rgba(139, 139, 139, 0.1);
    color: var(--color-secondary);
  }

  :global(.open-now-indicator__dot) {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  :global(.open-now-indicator__dot--green) {
    background-color: var(--color-success);
    animation: pulse 2s ease-in-out infinite;
  }

  :global(.open-now-indicator__dot--grey) {
    background-color: var(--color-secondary);
  }

  :global(.open-now-indicator__text) {
    line-height: var(--line-height-body);
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
</style>
