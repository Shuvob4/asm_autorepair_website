---
/**
 * Homepage — ASM AUTO Repair
 * Composes all homepage sections in the correct order.
 * Requirements: 1.1–1.9, 16.3
 */
import BaseLayout from '../components/layout/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import Benefits from '../components/home/Benefits.astro';
import ServicesOverview from '../components/home/ServicesOverview.astro';
import WhyChooseUs from '../components/home/WhyChooseUs.astro';
import Testimonials from '../components/home/Testimonials.astro';
import ReviewBadge from '../components/home/ReviewBadge.astro';
import PricingPreview from '../components/home/PricingPreview.astro';
---

<BaseLayout
  title="ASM AUTO Repair · Toronto's Trusted Auto Mechanic"
  description="Expert auto repair in Toronto. Oil changes, brake service, engine diagnostics. Visit us at 296 Brock Ave or request a free quote."
  canonical="https://asmautomotive.com/"
  includeJsonLd={true}
  transparentHeaderOnMobile={true}
>
  <Hero />
  <Benefits />
  <ServicesOverview />
  <WhyChooseUs />
  <Testimonials />
  <ReviewBadge />
  <PricingPreview />

  <!-- Contact / WhatsApp CTA Section -->
  <section class="contact-cta" aria-labelledby="contact-cta-heading">
    <div class="contact-cta__container">
      <h2 class="contact-cta__heading" id="contact-cta-heading">Ready to Get Started?</h2>
      <p class="contact-cta__text">
        Book your appointment or ask us anything — we're just a message away.
      </p>
      <a
        href="https://wa.me/13435585301"
        class="contact-cta__button"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contact us on WhatsApp"
      >
        <svg class="contact-cta__icon" aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Chat on WhatsApp
      </a>
      <p class="contact-cta__address">
        296 Brock Ave, Toronto
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-cta {
    padding: var(--space-xl) 0;
    background-color: var(--color-primary);
    text-align: center;
  }

  .contact-cta__container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .contact-cta__heading {
    font-family: var(--font-family);
    font-size: var(--text-h2);
    font-weight: var(--font-weight-bold);
    color: var(--color-white);
    margin: 0 0 var(--space-sm) 0;
    line-height: var(--line-height-heading);
  }

  .contact-cta__text {
    font-family: var(--font-family);
    font-size: var(--text-body);
    font-weight: var(--font-weight-regular);
    color: var(--color-secondary);
    margin: 0 0 var(--space-md) 0;
    line-height: var(--line-height-body);
  }

  .contact-cta__button {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    background-color: #25D366;
    color: var(--color-white);
    font-family: var(--font-family);
    font-size: var(--text-body);
    font-weight: var(--font-weight-bold);
    text-decoration: none;
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--border-radius-sm);
    min-height: var(--touch-min);
    min-width: var(--touch-min);
    transition: background-color var(--transition-fast);
  }

  .contact-cta__button:hover {
    background-color: #1DA851;
  }

  .contact-cta__button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .contact-cta__icon {
    flex-shrink: 0;
  }

  .contact-cta__address {
    font-family: var(--font-family);
    font-size: var(--text-body);
    font-weight: var(--font-weight-regular);
    color: var(--color-secondary);
    margin: var(--space-md) 0 0 0;
    line-height: var(--line-height-body);
  }
</style>
